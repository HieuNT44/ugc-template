# NextAuth.js
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# API (Laravel — server uses API_BASE_URL; client should call BFF, not BE directly)
API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
# Shared secret for Next.js BFF -> Laravel internal purchase fulfillment
INTERNAL_API_KEY=

# Google Sign-In (id_token for POST /auth/social/google)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# App URL (for Stripe success/cancel redirects; optional, falls back to request origin)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe (payments)
# Get keys: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Webhook secret: create at https://dashboard.stripe.com/webhooks or use Stripe CLI: stripe listen --forward-to localhost:3000/api/payment/stripe/webhook
STRIPE_WEBHOOK_SECRET=

# GMO Payment Gateway (Japan)
# Test: https://pt01.mul-pay.jp / Production: https://p01.mul-pay.jp
GMO_ENDPOINT=https://pt01.mul-pay.jp
GMO_SITE_ID=
GMO_SITE_PASS=
GMO_SHOP_ID=
GMO_SHOP_PASS=

# Firebase Configuration (client)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (server — service account for NextAuth + Firestore user profiles)
# Create: Firebase Console → Project settings → Service accounts → Generate new private key
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# Paste private key; use \n for line breaks in .env.local
FIREBASE_ADMIN_PRIVATE_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook OAuth
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Instagram OAuth
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# LINE OAuth
LINE_CLIENT_ID=
LINE_CLIENT_SECRET=
